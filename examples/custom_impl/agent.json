{
  "version": "1.0",
  "agents": [
    {
      "id": "assistant_custom",
      "name": "custom-agent",
      "memory": {
        "impl": "plugins.CustomMemory",
        "config": {
          "state_key": "custom_memory_items"
        },
        "on_error": "continue"
      },
      "pattern": {
        "impl": "plugins.CustomPattern",
        "config": {}
      },
      "tools": [
        {
          "id": "weather",
          "impl": "plugins.WeatherTool",
          "enabled": true,
          "config": {}
        }
      ],
      "runtime": {
        "max_steps": 8,
        "step_timeout_ms": 30000,
        "session_queue_size": 1000,
        "event_queue_size": 2000
      }
    }
  ]
}
