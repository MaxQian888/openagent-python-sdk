{
  "version": "1.0",
  "agents": [
    {
      "id": "custom-agent",
      "name": "custom-agent",
      "memory": {
        "impl": "examples.custom_impl.plugins.CustomMemory",
        "on_error": "continue"
      },
      "pattern": {
        "impl": "examples.custom_impl.plugins.CustomPattern"
      },
      "llm": {
        "provider": "mock"
      },
      "tools": [
        {
          "id": "custom_tool",
          "impl": "examples.custom_impl.plugins.CustomTool",
          "config": {
            "prefix": "custom"
          }
        }
      ],
      "runtime": {
        "max_steps": 8,
        "step_timeout_ms": 1000,
        "session_queue_size": 100,
        "event_queue_size": 100
      }
    }
  ]
}
