{
  "version": "1.0",
  "runtime": {
    "type": "default"
  },
  "session": {
    "type": "in_memory"
  },
  "events": {
    "type": "async"
  },
  "agents": [
    {
      "id": "file_manager",
      "name": "File Manager Agent",
      "enabled": true,
      "memory": {
        "type": "window_buffer",
        "config": {
          "window_size": 20
        },
        "on_error": "continue"
      },
      "pattern": {
        "type": "plan_execute",
        "config": {
          "max_steps": 30,
          "step_timeout_ms": 60000
        }
      },
      "llm": {
        "provider": "openai_compatible",
        "model": "LongCat-Flash-Chat",
        "api_base": "https://api.longcat.chat/openai/v1",
        "api_key_env": "LONGCAT_API_KEY",
        "temperature": 0.5,
        "max_tokens": 4096,
        "timeout_ms": 120000
      },
      "tools": [
        {
          "id": "read",
          "type": "read_file",
          "enabled": true,
          "config": {}
        },
        {
          "id": "write",
          "type": "write_file",
          "enabled": true,
          "config": {}
        },
        {
          "id": "list",
          "type": "list_files",
          "enabled": true,
          "config": {}
        },
        {
          "id": "delete",
          "type": "delete_file",
          "enabled": true,
          "config": {}
        },
        {
          "id": "grep",
          "type": "grep_files",
          "enabled": true,
          "config": {}
        },
        {
          "id": "calc",
          "type": "calc",
          "enabled": true,
          "config": {}
        },
        {
          "id": "json_parse",
          "type": "json_parse",
          "enabled": true,
          "config": {}
        }
      ]
    }
  ]
}
