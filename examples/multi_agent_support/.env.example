# multi_agent_support real-LLM demo configuration.
# Copy this file to `.env` and fill in credentials for an Anthropic-compatible endpoint
# (MiniMax is the default target, matching other examples in the repo).

LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.minimax.chat/anthropic
LLM_MODEL=abab6.5-chat
