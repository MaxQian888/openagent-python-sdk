{
  "version": "1.0",
  "runtime": {
    "type": "default"
  },
  "session": {
    "type": "in_memory"
  },
  "events": {
    "type": "async"
  },
  "agents": [
    {
      "id": "qa_assistant",
      "name": "Persistent QA Assistant",
      "memory": {
        "impl": "examples.persistent_qa.plugins.persistent_memory.PersistentMemory",
        "config": {
          "storage_dir": ".agent_memory",
          "max_items": 100
        }
      },
      "pattern": {
        "type": "react",
        "config": {
          "max_steps": 5
        }
      },
      "llm": {
        "provider": "anthropic",
        "api_base": "https://api.minimax.chat/anthropic/v1",
        "api_key_env": "MINIMAX_API_KEY",
        "model": "MiniMax-M2.7",
        "timeout_ms": 60000
      },
      "tools": [
        {
          "id": "search",
          "type": "builtin_search",
          "enabled": true
        },
        {
          "id": "calc",
          "type": "calc",
          "enabled": true
        }
      ],
      "runtime": {
        "max_steps": 5,
        "step_timeout_ms": 30000
      }
    }
  ]
}