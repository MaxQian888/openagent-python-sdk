{
  "version": "1.0",
  "runtime": {
    "type": "default"
  },
  "session": {
    "type": "in_memory"
  },
  "events": {
    "type": "async"
  },
  "agents": [
    {
      "id": "test_agent",
      "name": "Test Agent",
      "enabled": true,
      "memory": {
        "type": "buffer"
      },
      "pattern": {
        "type": "react",
        "config": {
          "max_steps": 3,
          "step_timeout_ms": 30000
        }
      },
      "llm": {
        "provider": "openai_compatible",
        "model": "LongCat-Flash-Chat",
        "api_base": "https://api.longcat.chat/openai/v1",
        "api_key_env": "LONGCAT_API_KEY",
        "temperature": 0.7,
        "max_tokens": 1024,
        "timeout_ms": 60000
      },
      "tools": [
        {
          "id": "calc",
          "type": "calc",
          "enabled": true
        },
        {
          "id": "current_time",
          "type": "current_time",
          "enabled": true
        }
      ]
    }
  ]
}
