# ── Required ────────────────────────────────────────────────────────────────
# OpenAI-compatible API key (Anthropic, MiniMax, OpenAI, etc.)
LLM_API_KEY=

# Base URL of the LLM provider
# Anthropic-compatible: https://api.anthropic.com
# MiniMax:              https://api.minimaxi.chat/v1
# OpenAI:               https://api.openai.com/v1
LLM_API_BASE=https://api.anthropic.com

# Model name as expected by the provider
# e.g. claude-sonnet-4-6 / claude-opus-4-7 / gpt-4o
LLM_MODEL=claude-sonnet-4-6

# ── Optional — Research stage ────────────────────────────────────────────────
# Tavily API key — enables web research in stage 3.
# Get one at https://tavily.com/
# TAVILY_API_KEY=

# ── Optional — Output paths ──────────────────────────────────────────────────
# Override the root directory for all project outputs.
# Default: examples/pptx_generator/outputs
# PPTX_AGENT_OUTPUTS=

# Override the per-project event log path.
# Default: outputs/<slug>/events.jsonl
# PPTX_EVENTS_LOG=
