{
  "version": "1.0",
  "runtime": {
    "type": "default"
  },
  "session": {
    "type": "in_memory"
  },
  "events": {
    "type": "async"
  },
  "agents": [
    {
      "id": "researcher",
      "name": "Research Agent",
      "enabled": true,
      "memory": {
        "type": "window_buffer",
        "config": {
          "window_size": 30
        },
        "on_error": "continue"
      },
      "pattern": {
        "type": "react",
        "config": {
          "max_steps": 20,
          "step_timeout_ms": 60000
        }
      },
      "llm": {
        "provider": "openai_compatible",
        "model": "LongCat-Flash-Chat",
        "api_base": "https://api.longcat.chat/openai/v1",
        "api_key_env": "LONGCAT_API_KEY",
        "temperature": 0.7,
        "max_tokens": 4096,
        "timeout_ms": 120000
      },
      "tools": [
        {
          "id": "search",
          "type": "builtin_search",
          "enabled": true,
          "config": {}
        },
        {
          "id": "http",
          "type": "http_request",
          "enabled": true,
          "config": {}
        },
        {
          "id": "url_parse",
          "type": "url_parse",
          "enabled": true,
          "config": {}
        }
      ]
    }
  ]
}
